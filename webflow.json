{
  "siteId": "6a034d161254a8d8ce2fc48a",
  "library": {
    "id": "webflow-studio-library",
    "name": "ACG Components Internal",
    "components": [
      "./src/components/ACGNavbar/ACGNavbar.webflow.tsx",
      "./src/components/ArrowButton/ArrowButton.webflow.tsx",
      "./src/components/GetInTouchButton/GetInTouchButton.webflow.tsx",
      "./src/components/MarqueeTitle/MarqueeTitle.webflow.tsx",
      "./src/components/ProjectCard/ProjectCard.webflow.tsx"
    ],
    "globals": "./src/global.webflow.ts"
  },
  "devlink": {
    "rootDir": "./devlink",
    "cssModules": true,
    "overwriteModule": true,
    "skipTagSelectors": false,
    "relativeHrefRoot": false,
    "fileExtensions": {
      "js": "tsx",
      "css": "css"
    }
  },
  "devlink-export": {
    "rootDir": "./devlink",
    "components": ".*",
    "componentGroups": ".*",
    "ts": true,
    "cssScopes": true,
    "treeShake": true,
    "relativeHrefRoot": false
  },
  "telemetry": {
    "global": {
      "allowTelemetry": false,
      "version": "2.0.0"
    }
  }
}
