{
  "name": "webflow-studio-library",
  "version": "1.0.0",
  "description": "Webflow DevLink code component library.",
  "type": "module",
  "private": true,
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "scripts": {
    "auth": "webflow auth login --skip-update-check",
    "auth:force": "webflow auth login --force --skip-update-check",
    "auth:logout": "webflow auth logout --skip-update-check",
    "auth:status": "webflow auth status --skip-update-check",
    "build": "pnpm run typecheck && vite build",
    "build:dev": "webflow devlink bundle --dev --skip-update-check --output-path dist",
    "bundle": "pnpm run build",
    "clean": "rimraf dist preview-dist .turbo .cache",
    "dev": "vite --host 0.0.0.0",
    "devlink:bundle": "pnpm run typecheck && webflow devlink bundle --no-input --skip-update-check --output-path dist",
    "devlink:bundle:dev": "webflow devlink bundle --dev --skip-update-check --output-path dist",
    "deploy": "pnpm run upload",
    "deploy:cloud": "webflow cloud deploy --skip-update-check",
    "download": "webflow devlink export --skip-update-check",
    "download:ci": "webflow devlink export --no-input --skip-update-check",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "library:build": "pnpm run devlink:bundle",
    "library:build:dev": "pnpm run devlink:bundle:dev",
    "library:deploy": "pnpm run library:upload",
    "library:download": "pnpm run download",
    "library:download:ci": "pnpm run download:ci",
    "library:preflight": "pnpm run lint && pnpm run typecheck && pnpm run library:build",
    "library:upload": "pnpm run upload",
    "library:upload:ci": "pnpm run upload:ci",
    "library:upload:dev": "pnpm run upload:dev",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "logs": "webflow log",
    "preflight": "pnpm run lint && pnpm run typecheck && pnpm run build",
    "preview": "vite preview --host 0.0.0.0",
    "preview:build": "pnpm run typecheck && vite build",
    "test": "pnpm run typecheck",
    "typecheck": "tsc --noEmit",
    "upload": "pnpm run typecheck && webflow devlink import --skip-update-check",
    "upload:ci": "pnpm run typecheck && webflow devlink import --no-input --skip-update-check",
    "upload:dev": "webflow devlink import --dev --skip-update-check",
    "webflow": "webflow --skip-update-check"
  },
  "keywords": [],
  "author": "",
  "license": "UNLICENSED",
  "dependencies": {
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/react": "^19.2.16",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "@webflow/data-types": "^2.0.0",
    "@webflow/react": "^2.0.0",
    "@webflow/webflow-cli": "^2.0.0",
    "eslint": "^10.4.1",
    "globals": "^17.6.0",
    "prettier": "^3.8.3",
    "rimraf": "^6.1.3",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.60.1",
    "vite": "^8.0.16"
  }
}
